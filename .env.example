# Megaverse Live - Environment Configuration Template
# Copy this file to .env and fill in your actual values
# Never commit .env with real credentials to git!

# ===== DATABASE CONFIGURATION =====
DB_HOST=megaverse-db.postgres.database.azure.com
DB_USER=dbadmin@megaverse-db
DB_PASSWORD=your_azure_db_password_here
DB_NAME=bookings
DB_PORT=5432

# ===== RAZORPAY (UPI Payments) =====
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# ===== PAYPAL (International Payments) =====
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
# For testing: https://api.sandbox.paypal.com
# For production: https://api.paypal.com
PAYPAL_API_URL=https://api.sandbox.paypal.com

# ===== FRONTEND CONFIGURATION =====
# This is the URL where your frontend is hosted
FRONTEND_URL=https://megaverselive.com

# ===== APPLICATION CONFIGURATION =====
NODE_ENV=production
PORT=8080

# ===== OPTIONAL: EMAIL CONFIGURATION =====
# For email notifications (optional)
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASSWORD=
# ADMIN_EMAIL=admin@megaverselive.com

# ===== OPTIONAL: WHATSAPP NOTIFICATIONS =====
# For WhatsApp notifications (optional)
# WHATSAPP_API_URL=
# WHATSAPP_API_TOKEN=
# WHATSAPP_BUSINESS_PHONE=

# ===== OPTIONAL: MONITORING =====
# LOG_LEVEL=info
